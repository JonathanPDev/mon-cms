            <i data-lucide="paperclip" class="icon-chat"></i>
          </button>
          <button class="icon-btn">
            <i data-lucide="phone" class="icon-chat"></i>
          </button>
          <button class="icon-btn">
            <i data-lucide="video" class="icon-chat"></i>
          </button>
        </div>
      </div>

    </header>

    <div class="message-chat-body">
      <div class="message-row received">
        <div class="message-bubble">
          Salut, tu peux me dire où en est le projet ?
          <span>14:25</span>
        </div>
      </div>

      <div class="message-row sent">
        <div class="message-bubble">
          Oui, j’ai presque fini la page dashboard.
          <span>14:27</span>
        </div>
      </div>

      <div class="message-row received">
        <div class="message-bubble">
          Parfait, envoie-moi une preview quand tu peux.
          <span>14:32</span>
        </div>
      </div>
    </div>

    <form class="message-chat-form">
      <button type="button" class="icon-btn">+</button>
      <input type="text" placeholder="Écrire un message...">
      <button type="submit" class="send-btn">Envoyer</button>
    </form>
  </section>
