<div class="hero">
    <div class="main-stack">
        <section class="card mesProjet">
            <div class="header-projet">
                <h3>Projet recent</h3>

                <div class="card-menu">
                    <button type="button" class="card-menu-trigger" aria-label="Ouvrir les options">
                        <i data-lucide="ellipsis-vertical" class="icon-topaction"></i>
                    </button>

                    <div class="setting-bar">
                        <i data-lucide="trash-2" class="setting-icon"></i>
                        <i data-lucide="list" class="setting-icon btn-view-list"></i>
                        <i data-lucide="grid-2x2" class="setting-icon btn-view-grid active"></i>
                        <i data-lucide="plus" class="setting-icon"></i>
                    </div>
                </div>
            </div>

            <div class="project-grid">
                <% if (projects && projects.length > 0) { %>
                    <% projects.forEach(project => { %>
                        <article class="project-card">
                            <div class="project-card__top">
                                <div>
                                    <p class="project-card__eyebrow">Projet</p>
                                    <h4 class="project-card__title">
                                        <%= project.name %>
                                    </h4>
                                </div>
                                
                                
                                <span class="badge badge-status badge-status-<%= project.status %>">
                                    <%= project.status %>
                                </span>
                            </div>
                        </article>
                    <% }) %>
                <% } else { %>
                    <p>Aucun projet pour le moment.</p>
                <% } %>
            </div>

            <div class="mesProjet-resize-handle-y" aria-hidden="true"></div>
        </section>

        <section class="card statistique">
            <div class="card-menu">
                <button type="button" class="card-menu-trigger" aria-label="Ouvrir les options">
                    <i data-lucide="ellipsis-vertical" class="icon-topaction"></i>
                </button>

                <div class="setting-bar">
                    <i data-lucide="trash-2" class="setting-icon"></i>
                    <i data-lucide="expand" class="setting-icon"></i>
                    <i data-lucide="plus" class="setting-icon"></i>
                </div>
            </div>

            <h3>Statistique</h3>
            <p>
                Lorem ipsum dolor sit amet consectetur adipisicing elit. Temporibus, minus.
                Eius perspiciatis, deserunt saepe odit rem quam reprehenderit ab adipisci
                veniam ipsa in sit eligendi nulla laboriosam iusto quas architecto?
            </p>
        </section>
    </div>

    <div class="side-stack">
        <section class="card action-rapide">
            <div class="card-menu">
                <button type="button" class="card-menu-trigger" aria-label="Ouvrir les options">
                    <i data-lucide="ellipsis-vertical" class="icon-topaction"></i>
                </button>

                <div class="setting-bar">
                    <i data-lucide="trash-2" class="setting-icon"></i>
                    <i data-lucide="expand" class="setting-icon"></i>
                    <i data-lucide="plus" class="setting-icon"></i>
                </div>
            </div>

            <h3>Actions rapide</h3>
            <div class="quick-list">
                <div class="quick-action">
                    <i data-lucide="plus" class="quick-icon"></i>
                    <strong>Créer un projet</strong>
                </div>
                <div class="quick-action">
                    <i data-lucide="pencil" class="quick-icon"></i>
                    <strong>Edité un projet</strong>
                </div>
                <div class="quick-action">
                    <i data-lucide="chart-spline" class="quick-icon"></i>
                    <strong>Statistique</strong>
                </div>
                <div class="quick-action">
                    <i data-lucide="headset" class="quick-icon"></i>
                    <strong>Besoin d'aide ?</strong>
                </div>
            </div>
        </section>

        <section class="card recent-activities">
            <div class="card-menu">
                <button type="button" class="card-menu-trigger" aria-label="Ouvrir les options">
                    <i data-lucide="ellipsis-vertical" class="icon-topaction"></i>
                </button>

                <div class="setting-bar">
                    <i data-lucide="trash-2" class="setting-icon"></i>
                    <i data-lucide="expand" class="setting-icon"></i>
                    <i data-lucide="plus" class="setting-icon"></i>
                </div>
            </div>

            <h3>Activités recentes</h3>
            Lorem ipsum dolor sit amet consectetur adipisicing elit. Nemo accusamus similique,
            autem quaerat ipsa perferendis rem magni, quibusdam non vel nesciunt, delectus
            pariatur maiores aspernatur eos sequi ab aut libero!
        </section>
    </div>
</div>